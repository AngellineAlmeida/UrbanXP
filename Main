import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        
        System.out.print("Nome do cliente: ");
        String nome = scanner.nextLine();
        
        System.out.println("Selecione o desconto: 1-Padrao, 2-50%, 3-Premium");
        int opcao = scanner.nextInt();
        
        Desconto politica;
      
        switch (opcao) {
            case 2: politica = new Desconto50Porcento(); break;
            case 3: politica = new DescontoPremium(); break;
            default: politica = new DescontoPadrao(); break;
        }
        
        Cliente cliente = new Cliente(nome, politica);
        double precoBase = 100.0;
        
        System.out.println("\nResumo:");
        System.out.println("Cliente: " + cliente.getNome());
        System.out.println("Valor final: R$ " + cliente.calcularValorFinal(precoBase));
        
        scanner.close();
    }
}
